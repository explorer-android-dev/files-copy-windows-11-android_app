<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Dark theme for night mode (Dark Mica design) -->
    <style name="Theme.Windows11Files" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">#0078D4</item>
        <item name="colorPrimaryVariant">#106EBE</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">#0078D4</item>
        <item name="colorSecondaryVariant">#106EBE</item>
        <item name="colorOnSecondary">#FFFFFF</item>
        <!-- Tertiary color -->
        <item name="colorTertiary">#0078D4</item>
        <item name="colorTertiaryContainer">#DCE2FF</item>
        <item name="colorOnTertiaryContainer">#001947</item>
        <!-- Dark mode colors (Dark Mica theme) -->
        <item name="android:colorBackground">#1E1E1E</item>
        <item name="colorSurface">#2D2D2D</item>
        <item name="colorOnSurface">#FFFFFF</item>
        <item name="colorError">#F2B8B5</item>
        <!-- Status bar and navigation colors for dark mode -->
        <item name="android:statusBarColor" tools:targetApi="l">#1E1E1E</item>
        <item name="android:navigationBarColor">#2D2D2D</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
    </style>
</resources>
